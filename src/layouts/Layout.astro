---
import Header from '../components/header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/icon1.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="wrapper">
			<Header />
			<slot />
			<Footer />
		</div>
	</body>
</html>
<style is:global>
@import url('https://fonts.googleapis.com/css2?family=BIZ+UDGothic:wght@400;700&family=Source+Code+Pro:ital,wght@0,200..900;1,200..900&display=swap');

* {
    font-family: "Source Code Pro", "BIZ UDGothic", sans-serif;
    margin: 0;
    padding: 0;
}

.wrapper {
    margin: 0 auto;
    max-width: 1140px;
    width: 100%;
    font-size: 1em;
	font-weight: 500;
}

body {
    color: #333;
    height: 100%;
	font-weight: 500;
}

h2 {
	font-weight: 500;
}

main {
    margin: 0 3em;
}

main p, ul, li, a {
        font-size: 1.05em;
        line-height: 1.6;
    }

    main ul {
        padding: 0 0 .5em;
    }

    main h3 {
        font-weight: 600;
        font-size: 1.2em;
        position: relative;
        border-bottom: 5px solid #ddd;
        margin: 0 0 .5em;
        padding: 0 0 .3em;
    }

    main h3:before {
        position: absolute;
        left: 0;
        bottom: -5px;
        width: 20%;
        height: 5px;
        content: '';
        background: #27acd9;
    }

    main li {
        margin-left: 1.5em;
        padding-top: .2em;
    }

    main .box {
        padding: .5em 0;
    }

    main .email {
        background-color: #f8efef;
        padding: .5em;
        width: fit-content;
    }
</style>
