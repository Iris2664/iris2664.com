---
import Header from '../components/header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://www.iris2664.com/');
const ogpImageURL = new URL('/icon1.png', canonicalURL);
---

<!doctype html>
<html lang="ja">
	<head prefix="og: https://ogp.me/ns#">
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/icon1.png" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=BIZ+UDGothic:wght@400;700&family=Source+Code+Pro:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="author" content="陽向あやめ">
		<meta name="description" content="陽向あやめ. Bachelor Students (Information), Security Researcher, ICT Engineer, Virtual YouTuber">
		<meta property="og:title" content="iris2664.com">
		<meta property="og:description" content="陽向あやめ. Bachelor Students (Information), Security Researcher, ICT Engineer, Virtual YouTuber">
		<meta property="og:url" content="https://www.iris2664.com/">
		<meta property="og:image" content="{ogpImageURL}">
		<meta property="og:type" content="website">
		<meta property="og:site_name" content="iris2664.com">
		<!-- X(Twitter) -->
		<meta name="twitter:card" content="summary">
		<meta name="twitter:site" content="@Iris2664">
		<meta name="twitter:title" content="iris2664.com">
		<meta name="twitter:description" content="陽向あやめ. Bachelor Students (Information), Security Researcher, ICT Engineer, Virtual YouTuber">
		<meta name="twitter:image" content="{ogpImageURL}">
	</head>
	<body>
		<div class="wrapper">
			<Header />
			<slot />
			<Footer />
		</div>
	</body>
</html>
<style is:global>
* {
    font-family: "Source Code Pro", "BIZ UDGothic", sans-serif;
    margin: 0;
    padding: 0;
}

.wrapper {
    margin: 0 auto;
    max-width: 1140px;
    width: 100%;
    font-size: 1em;
	font-weight: 500;
}

body {
    color: #333;
    height: 100%;
	font-weight: 500;
}

h2 {
	font-weight: 500;
}

main {
    margin: 0 3em;
}

main p, ul, li, a {
        font-size: 1.05em;
        line-height: 1.6;
    }

    main ul {
        padding: 0 0 .5em;
    }

    main h3 {
        font-weight: 600;
        font-size: 1.2em;
        position: relative;
        border-bottom: 5px solid #ddd;
        margin: 0 0 .5em;
        padding: 0 0 .3em;
    }

    main h3:before {
        position: absolute;
        left: 0;
        bottom: -5px;
        width: 20%;
        height: 5px;
        content: '';
        background: #27acd9;
    }

    main li {
        margin-left: 1.5em;
        padding-top: .2em;
    }

    main .box {
        padding: .5em 0;
    }

    main .email {
        background-color: #f8efef;
        padding: .5em;
        width: fit-content;
    }
</style>
